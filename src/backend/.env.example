EMAIL_PASSWORD=

# generated locally on powershell using [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=

# Optional overrides (defaults defined in application.properties, values in ms)
# JWT_EXPIRATION=3600000
# VERIFICATION_TOKEN_EXPIRATION=1800000
# RESET_TOKEN_EXPIRATION=900000

# Swagger UI / OpenAPI docs - on by default in the dev profile already, no
# need to set this to see it locally. Uncomment to force it off even in dev.
# SWAGGER_UI_ENABLED=false

# Postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# pgAdmin
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
PGADMIN_PORT=
